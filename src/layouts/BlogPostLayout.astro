---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Comments from '../components/Comments.astro';

const { title, description, pubDate, category, author, formattedDate, slug } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title} | Ahmed's Blog</title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="/global.css">
</head>
<body>
  <Header />
  <main class="container">
    <article class="post">
      <header class="post-header">
        <div class="category-badge">{category}</div>
        <h1>{title}</h1>
        <div class="post-meta">
          <time datetime={pubDate}>
            <svg class="clock-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {formattedDate}
          </time>
          <span>•</span>
          <span>By {author}</span>
        </div>
      </header>
      
      <div class="post-content">
        <slot />
      </div>
      
      <Comments postSlug={slug} />
    </article>
  </main>
  <Footer />
</body>
</html>

<style>
  main {
    min-height: calc(100vh - 200px);
    padding: 3rem 0;
  }

  .post {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .category-badge {
    display: inline-block;
    background-color: var(--accent);
    color: var(--bg-primary);
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .post-header h1 {
    font-size: 3rem;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
    align-items: center;
  }

  .post-meta time {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .clock-icon {
    flex-shrink: 0;
    opacity: 0.8;
  }

  .post-content {
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .post-content p {
    margin: 1.5rem 0;
  }

  @media (max-width: 1024px) {
    main {
      padding: 2.5rem 0;
    }

    .post-header h1 {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    main {
      padding: 2rem 0;
    }

    .post-header {
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
    }

    .post-header h1 {
      font-size: 1.875rem;
      line-height: 1.3;
    }

    .category-badge {
      padding: 0.375rem 0.875rem;
      font-size: 0.8rem;
      margin-bottom: 1rem;
    }

    .post-meta {
      flex-wrap: wrap;
      gap: 0.5rem;
      font-size: 0.875rem;
    }

    .post-content {
      font-size: 1rem;
      line-height: 1.7;
    }

    .post-content p {
      margin: 1.25rem 0;
    }
  }

  @media (max-width: 480px) {
    main {
      padding: 1.5rem 0;
    }

    .post-header {
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
    }

    .post-header h1 {
      font-size: 1.5rem;
    }

    .category-badge {
      font-size: 0.75rem;
    }

    .post-meta {
      font-size: 0.8rem;
    }

    .post-content {
      font-size: 0.9375rem;
    }

    .post-content h2 {
      font-size: 1.5rem;
    }

    .post-content h3 {
      font-size: 1.25rem;
    }
  }
</style>
