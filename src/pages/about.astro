---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Ahmed - System Administrator & IT Infrastructure Specialist">
  <div class="container">
    <section class="about">
      <div class="about-header">
        <div class="about-avatar">
          <img src="/avatar.png" alt="Ahmed Amin" class="avatar-image" />
        </div>
        <div class="about-intro">
          <h1>Ahmed Amin</h1>
          <p class="role">Tech Enthusiast</p>
        </div>
      </div>

      <div class="about-content">
        <div class="about-section">
          <h2>About Me</h2>
          <p>
            Hey there! I'm Ahmed — a tech enthusiast who's still figuring things out, one command line and
            one troubleshooting session at a time. I'm not claiming to be a guru; think of me more as a
            work‑in‑progress who enjoys sharing the journey.
          </p>
          <p>
            I like to keep things light and fun, because tech doesn't always have to be intimidating (it is
            sometimes). Whether it's experimenting with Linux setups, tinkering with cloud networking, or just
            breaking things (and hopefully fixing them again), I'm here to learn and laugh along the way.
          </p>
          <p>
            Side note: when I'm not knee deep in servers or scripts, you'll probably find me geeking out over
            cars. From resilient classic builds to modern day endurance machines, I love the engineering and
            design that goes into them — it's another kind of tech, just with wheels.
          </p>
          <p>
            So, welcome to my corner of the internet. Stick around, and let's explore the messy, exciting world
            of tech together.
          </p>
        </div>

        <div class="about-section">
          <h2>Certifications</h2>
          <div class="cert-marquee">
            <div class="cert-track">
              <div class="cert-card">
                <img src="/certifications/az104.png" alt="AZ-104" class="cert-image" />
                <span class="cert-tag azure">Microsoft</span>
                <strong>AZ-104</strong>
                <p>Azure Administrator</p>
              </div>
              <div class="cert-card">
                <img src="/certifications/az700.png" alt="AZ-700" class="cert-image" />
                <span class="cert-tag azure">Microsoft</span>
                <strong>AZ-700</strong>
                <p>Azure Network Engineer</p>
              </div>
              <div class="cert-card">
                <img src="/certifications/vcp-vcf.png" alt="VCP-VCF" class="cert-image" />
                <span class="cert-tag vmware">VMware</span>
                <strong>VCP-VCF</strong>
                <p>VMware Cloud Foundation</p>
              </div>
              <div class="cert-card">
                <img src="/certifications/vmce.png" alt="VMCE" class="cert-image" />
                <span class="cert-tag veeam">Veeam</span>
                <strong>VMCE</strong>
                <p>Veeam Certified Engineer</p>
              </div>
              <!-- Duplicates for seamless loop -->
              <div class="cert-card" aria-hidden="true">
                <img src="/certifications/az104.png" alt="" class="cert-image" />
                <span class="cert-tag azure">Microsoft</span>
                <strong>AZ-104</strong>
                <p>Azure Administrator</p>
              </div>
              <div class="cert-card" aria-hidden="true">
                <img src="/certifications/az700.png" alt="" class="cert-image" />
                <span class="cert-tag azure">Microsoft</span>
                <strong>AZ-700</strong>
                <p>Azure Network Engineer</p>
              </div>
              <div class="cert-card" aria-hidden="true">
                <img src="/certifications/vcp-vcf.png" alt="" class="cert-image" />
                <span class="cert-tag vmware">VMware</span>
                <strong>VCP-VCF</strong>
                <p>VMware Cloud Foundation</p>
              </div>
              <div class="cert-card" aria-hidden="true">
                <img src="/certifications/vmce.png" alt="" class="cert-image" />
                <span class="cert-tag veeam">Veeam</span>
                <strong>VMCE</strong>
                <p>Veeam Certified Engineer</p>
              </div>
            </div>
          </div>
        </div>

        <div class="about-section">
          <h2>On-Premises Stack</h2>
          <div class="tech-grid">
            <div class="tech-category">
              <h3>Virtualization</h3>
              <ul>
                <li>VMware vSphere / ESXi</li>
                <li>VMware Cloud Foundation (VCF)</li>
                <li>Microsoft Hyper-V</li>
              </ul>
            </div>
            <div class="tech-category">
              <h3>Backup & DR</h3>
              <ul>
                <li>Veeam Backup & Replication</li>
              </ul>
            </div>

          </div>
        </div>

        <div class="about-section">
          <h2>Cloud Stack</h2>
          <div class="tech-grid">
            <div class="tech-category">
              <h3>Cloud Platform</h3>
              <ul class="two-col-list">
                <li>Microsoft Azure</li>
                <li>Microsoft 365</li>
                <li>Microsoft Intune</li>
                <li>Linode</li>
                <li>Amazon Web Services</li>
                <li>Google Cloud Platform</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="about-section">
          <h2>Security & Patching</h2>
          <div class="tech-grid two-col">
            <div class="tech-category">
              <h3>Security & Monitoring</h3>
              <ul>
                <li>Azure Sentinel</li>
                <li>Wazuh</li>
                <li>Microsoft Defender</li>
                <li>LogicMonitor</li>
                <li>Veeam ONE Monitoring</li>
                <li>PRTG</li>
              </ul>
            </div>
            <div class="tech-category">
              <h3>Patching</h3>
              <ul>
                <li>Azure Update Manager</li>
                <li>WSUS Patching</li>
                <li>Tanium</li>
                <li>SolarWinds Patch Manager</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="about-section">
          <h2>What This Blog Covers</h2>
          <div class="topics">
            <span class="topic">Backups</span>
            <span class="topic">Virtualization</span>
            <span class="topic">Cloud</span>
            <span class="topic">Monitoring</span>
            <span class="topic">Networking</span>
            <span class="topic">Security</span>
            <span class="topic">Automation</span>
            <span class="topic">Windows Server</span>
            <span class="topic">Linux</span>
          </div>
        </div>

        <div class="about-section">
          <h2>Location</h2>
          <p>Based in Pakistan (Asia/Karachi, GMT+5)</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .about {
    max-width: 800px;
    margin: 0 auto;
  }

  .about-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .avatar-image {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .about-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.25rem;
  }

  .role {
    color: var(--accent);
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }


  .about-section {
    margin-bottom: 3rem;
  }

  .about-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--accent);
    display: inline-block;
  }

  .about-section p {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .cert-marquee {
    overflow: hidden;
    position: relative;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    margin: 0 -1.5rem;
    padding: 1rem 0;
  }

  .cert-track {
    display: flex;
    gap: 1.5rem;
    width: max-content;
    animation: marquee 25s linear infinite;
  }

  .cert-marquee:hover .cert-track {
    animation-play-state: paused;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .cert-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    min-width: 220px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    flex-shrink: 0;
  }

  .cert-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(255, 107, 53, 0.15);
  }

  .cert-card .cert-image {
    width: 80px;
    height: 80px;
    object-fit: contain;
  }

  .cert-card strong {
    color: var(--text-primary);
    font-size: 1.1rem;
  }

  .cert-card p {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin: 0;
    line-height: 1.3;
  }

  .cert-tag {
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cert-tag.azure {
    background: linear-gradient(135deg, #00a4ef, #0078d4);
    color: white;
  }

  .cert-tag.vmware {
    background: linear-gradient(135deg, #696566, #3d3d3d);
    color: white;
  }

  .cert-tag.veeam {
    background: linear-gradient(135deg, #00b336, #008026);
    color: white;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .tech-grid.two-col {
    grid-template-columns: repeat(2, 1fr);
  }

  @media (max-width: 768px) {
    .tech-grid.two-col {
      grid-template-columns: 1fr;
    }
  }

  .tech-category {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
  }

  .tech-category h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    margin-top: 0;
    color: var(--accent);
  }

  .tech-category ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tech-category li {
    color: var(--text-secondary);
    padding: 0.3rem 0;
    padding-left: 1.25rem;
    position: relative;
    font-size: 0.95rem;
  }

  .tech-category li::before {
    content: "▸";
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .two-col-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.3rem 1.5rem;
  }

  @media (max-width: 600px) {
    .two-col-list {
      grid-template-columns: 1fr;
    }
  }

  .topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .topic {
    background-color: var(--bg-tertiary);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.875rem;
    transition: all 0.2s;
  }

  .topic:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .about-header {
      flex-direction: column;
      text-align: center;
    }

    .about-intro h1 {
      font-size: 1.75rem;
    }
  }
</style>
